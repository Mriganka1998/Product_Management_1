<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product Management</title>
    <style>
        body {
            margin: 0;
            padding-bottom: 60px;
            padding-top: 70px; /* Space for fixed header */
        }
        .header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            background-color: #4CAF50;
            color: white;
            padding: 15px 20px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
            z-index: 1000;
        }
        .header h1 {
            margin: 0;
            font-size: 24px;
        }
        .flash-message {
            position: fixed;
            top: 70px;
            left: 0;
            right: 0;
            z-index: 999;
        }
    </style>
</head>
<body>
    <header class="header">
        <h1>Product Management</h1>
    </header>
    <div class="flash-message">
        <% if (locals.success && success.length > 0) { %>
            <div style="color: green; padding: 10px; background-color: #d4edda; border: 1px solid #c3e6cb; margin-bottom: 10px;"><%= success[0] %></div>
        <% } %>
        <% if (locals.error && error.length > 0) { %>
            <div style="color: red; padding: 10px; background-color: #f8d7da; border: 1px solid #f5c6cb; margin-bottom: 10px;"><%= error[0] %></div>
        <% } %>
    </div>